---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us — MindChat AI" description="Learn about MindChat AI — your free, private AI chat assistant powered by Google Gemini.">
	<main class="page-container">

		<header class="header">
			<div class="header-left">
				<svg class="header-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" width="20" height="20" aria-hidden="true">
					<defs>
						<linearGradient id="header-logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="#ff3b30"/>
							<stop offset="100%" stop-color="#d42020"/>
						</linearGradient>
					</defs>
					<path d="M 48,24 H 80 C 93,24 104,35 104,48 V 72 C 104,85 93,96 80,96 H 58 L 40,110 V 96 H 48 C 35,96 24,85 24,72 V 48 C 24,35 35,24 48,24 Z" fill="url(#header-logo-grad)" opacity="0.08"/>
					<path d="M 48,24 H 80 C 93,24 104,35 104,48 V 72 C 104,85 93,96 80,96 H 58 L 40,110 V 96 H 48 C 35,96 24,85 24,72 V 48 C 24,35 35,24 48,24 Z" fill="none" stroke="url(#header-logo-grad)" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
					<path d="M 46,70 V 54 C 46,43 55,43 59,50 L 64,57 L 69,50 C 73,43 82,43 82,54 V 70" fill="none" stroke="currentColor" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round"/>
					<circle cx="64" cy="57" r="3.5" fill="currentColor" />
					<circle cx="53.5" cy="46" r="2.5" fill="currentColor" />
					<circle cx="74.5" cy="46" r="2.5" fill="currentColor" />
				</svg>
				<span>MindChat AI</span>
			</div>
			<div class="header-right">
				<button class="theme-toggle interactive" id="theme-toggle" aria-label="Toggle theme">Light Mode</button>
				<span class="divider">·</span>
				<a href="/" class="header-link interactive">← Home</a>
			</div>
		</header>

		<section class="content-section">
			<div class="content-container">
				<h1 class="content-heading invert-text">About Us</h1>

				<div class="content-body">
					<h2>Our Mission</h2>
					<p>MindChat AI was created with a simple mission: make artificial intelligence accessible, free, and private for everyone. We believe that powerful AI should not require sign-ups, subscriptions, or sacrificing your privacy.</p>

					<h2>What We Offer</h2>
					<p>MindChat AI is a free, privacy-first AI chat assistant powered by Google's advanced Gemini 2.5 Flash model. You can ask questions, brainstorm ideas, get writing help, learn new topics, and much more — all without creating an account or sharing personal information.</p>

					<h2>Our Values</h2>
					<p><strong>Privacy First:</strong> We do not store conversations or collect personal data. Your chats are anonymous and private.</p>
					<p><strong>Free for Everyone:</strong> No hidden fees, subscription plans, or usage limits. AI assistance should be accessible to all.</p>
					<p><strong>Built with Care:</strong> We use cutting-edge technology to provide accurate, thoughtful responses while continuously improving your experience.</p>

					<h2>Technology</h2>
					<p>MindChat AI is built with Astro, powered by Google Gemini 2.5 Flash, and hosted on Cloudflare Workers for fast, reliable performance worldwide.</p>

					<h2>Developer</h2>
					<p>Developed by <a href="https://www.linkedin.com/in/nived-mohan-23170432b/" class="content-link" target="_blank" rel="noopener noreferrer">Nived Mohan</a></p>
					<p><a href="mailto:nivedmohan5423@gmail.com" class="content-link">nivedmohan5423@gmail.com</a></p>
				</div>
			</div>
		</section>

		<footer class="footer">
			<div class="footer-item"><a href="/privacy" class="footer-link">Privacy Policy</a></div>
			<div class="footer-item"><a href="/about" class="footer-link">About Us</a></div>
			<div class="footer-item"><a href="/terms" class="footer-link">Terms & Conditions</a></div>
			<div class="footer-item"><a href="/contact" class="footer-link">Contact Us</a></div>
		</footer>

	</main>
</Layout>

<style>
	.page-container {
		display: flex; flex-direction: column;
		width: 100%; min-height: 100dvh; position: relative;
		background-color: var(--bg-color); overflow-y: auto;
	}

	:global(html), :global(body) {
		overflow: auto;
	}

	.header {
		display: flex; justify-content: space-between; align-items: center;
		width: 100%; padding: 2.5rem 3.5rem; z-index: 10;
	}

	.header-left {
		display: flex; align-items: center; gap: 0.6rem;
		font-size: 0.75rem; font-weight: 900; text-transform: uppercase;
		letter-spacing: 0.25em; color: var(--hero-color); font-variant: all-small-caps;
	}

	.header-logo {
		width: 20px; height: 20px; flex-shrink: 0;
	}

	.header-right {
		display: flex; align-items: center; gap: 0.75rem;
		font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
		letter-spacing: 0.2em; color: var(--hero-color);
	}

	.header-link { text-decoration: none; color: inherit; }
	.divider { color: var(--text-muted); }

	.theme-toggle {
		background: none; border: none; outline: none; cursor: pointer;
		font-family: 'Montserrat', sans-serif;
		font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
		letter-spacing: 0.2em; color: var(--hero-color); padding: 0;
		transition: letter-spacing 0.3s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s;
	}
	.theme-toggle:hover { letter-spacing: 0.3em; }

	.content-section {
		flex: 1; display: flex; justify-content: center;
		padding: 3rem 1.5rem 4rem;
	}

	.content-container {
		width: 100%; max-width: 800px;
		display: flex; flex-direction: column; gap: 1.5rem;
	}

	.content-heading {
		font-family: 'Montserrat', sans-serif;
		font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900;
		text-transform: uppercase; letter-spacing: -0.03em;
		text-align: center; color: #ffffff; mix-blend-mode: difference;
	}

	.content-body {
		display: flex; flex-direction: column; gap: 1.25rem;
	}

	.content-body h2 {
		font-family: 'Montserrat', sans-serif;
		font-size: 1.25rem; font-weight: 700; text-transform: uppercase;
		letter-spacing: 0.05em; color: var(--text-primary);
		margin-top: 1rem;
	}

	.content-body h2:first-child { margin-top: 0; }

	.content-body p {
		font-family: 'Montserrat', sans-serif;
		font-size: 1rem; font-weight: 400; line-height: 1.7;
		color: var(--text-secondary);
	}

	.footer {
		display: flex; justify-content: space-between; align-items: center;
		flex-wrap: wrap; gap: 1rem 2rem;
		width: 100%; padding: 2.5rem 3.5rem; z-index: 10;
	}

	.footer-item {
		font-size: 0.65rem; font-weight: 500; text-transform: uppercase;
		letter-spacing: 0.15em; font-variant: all-small-caps; white-space: nowrap;
	}

	.footer-link { text-decoration: none; color: var(--text-color); position: relative; padding-bottom: 2px; }
	.footer-link::after {
		content: ''; position: absolute; width: 100%; transform: scaleX(0);
		height: 1px; bottom: 0; left: 0; background-color: var(--text-color);
		transform-origin: bottom right; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.footer-link:hover::after { transform: scaleX(1); transform-origin: bottom left; }

	@media (max-width: 900px) {
		.header { padding: 1.25rem 1.5rem; }
	}

	@media (max-width: 768px) {
		.footer {
			justify-content: center;
			padding: 1.5rem;
			gap: 0.75rem 1.5rem;
		}
		.footer-item {
			font-size: 0.6rem;
			letter-spacing: 0.1em;
		}
	}

	@media (max-width: 600px) {
		.header { padding: 1rem 1.25rem; }
		.header-left { font-size: 0.65rem; letter-spacing: 0.15em; }
		.header-right { font-size: 0.65rem; letter-spacing: 0.1em; gap: 0.5rem; }
		.theme-toggle { font-size: 0.65rem; letter-spacing: 0.1em; }
		.content-section { padding: 2rem 1.25rem 3rem; }
	}
</style>
