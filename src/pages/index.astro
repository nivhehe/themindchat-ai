---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MindChat AI — Where Curiosity Meets Intelligence" description="MindChat AI is your free, private AI chat assistant. No sign-up needed. Ask anything, anytime.">
	<main class="page-container">

		<header class="header">
			<div class="header-left">
				<svg class="header-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" width="20" height="20" aria-hidden="true">
					<defs>
						<linearGradient id="header-logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="#ff3b30"/>
							<stop offset="100%" stop-color="#d42020"/>
						</linearGradient>
					</defs>
					<path d="M 48,24 H 80 C 93,24 104,35 104,48 V 72 C 104,85 93,96 80,96 H 58 L 40,110 V 96 H 48 C 35,96 24,85 24,72 V 48 C 24,35 35,24 48,24 Z" fill="url(#header-logo-grad)" opacity="0.08"/>
					<path d="M 48,24 H 80 C 93,24 104,35 104,48 V 72 C 104,85 93,96 80,96 H 58 L 40,110 V 96 H 48 C 35,96 24,85 24,72 V 48 C 24,35 35,24 48,24 Z" fill="none" stroke="url(#header-logo-grad)" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
					<path d="M 46,70 V 54 C 46,43 55,43 59,50 L 64,57 L 69,50 C 73,43 82,43 82,54 V 70" fill="none" stroke="currentColor" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round"/>
					<circle cx="64" cy="57" r="3.5" fill="currentColor" />
					<circle cx="53.5" cy="46" r="2.5" fill="currentColor" />
					<circle cx="74.5" cy="46" r="2.5" fill="currentColor" />
				</svg>
				<span>mindchat ai</span>
			</div>
			<div class="header-right">
				<button class="theme-toggle interactive" id="theme-toggle" aria-label="Toggle theme">Dark Mode</button>
			</div>
		</header>

		<div class="spline-wrapper">
			<spline-viewer url="https://prod.spline.design/sT38-ZSmhHN8uuqF/scene.splinecode" loading="eager" events-target="global"></spline-viewer>
			<div class="spline-loading"></div>
		</div>

		<section class="hero-section">
			<div class="hero-container">
				<h1 class="hero-text">
					<span class="invert-text">welcome to </span><span class="highlight-red">mindchat</span><span class="invert-text"> ai</span>
				</h1>
				<p class="hero-tagline invert-text">Where curiosity meets intelligence</p>
				<a href="/chat" class="get-started-btn" id="get-started-btn">
					get started
				</a>
			</div>
		</section>

		<footer class="footer">
			<div class="footer-item"><a href="/privacy" class="footer-link">Privacy Policy</a></div>
			<div class="footer-item"><a href="/about" class="footer-link">About Us</a></div>
			<div class="footer-item"><a href="/terms" class="footer-link">Terms & Conditions</a></div>
			<div class="footer-item"><a href="/contact" class="footer-link">Contact Us</a></div>
		</footer>

	</main>
</Layout>

<script>
	function showGetStarted() {
		const btn = document.getElementById('get-started-btn');
		if (!btn) return;
		btn.classList.remove('visible', 'blend-active');
		setTimeout(() => {
			btn.classList.add('visible');
			setTimeout(() => btn.classList.add('blend-active'), 1000);
		}, 3000);
	}

	document.addEventListener('astro:page-load', showGetStarted);
</script>

<style>
	.page-container {
		display: flex; flex-direction: column; justify-content: space-between;
		height: 100dvh; width: 100%; position: relative;
		background-color: var(--bg-color); overflow: hidden;
	}

	.header {
		display: flex; justify-content: space-between; align-items: center;
		width: 100%; padding: 2.5rem 3.5rem; z-index: 10;
		opacity: 0; animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
	}

	.header-left {
		display: flex; align-items: center; gap: 0.6rem;
		font-size: 0.75rem; font-weight: 900; text-transform: uppercase;
		letter-spacing: 0.25em; color: var(--hero-color); font-variant: all-small-caps;
	}

	.header-logo {
		width: 20px; height: 20px; flex-shrink: 0;
	}

	.header-right {
		display: flex; align-items: center; gap: 0.75rem;
		font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
		letter-spacing: 0.2em; color: var(--hero-color);
	}

	.theme-toggle {
		background: none; border: none; outline: none; cursor: pointer;
		font-family: 'Montserrat', sans-serif;
		font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
		letter-spacing: 0.2em; color: var(--hero-color); padding: 0;
		transition: letter-spacing 0.3s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s;
	}
	.theme-toggle:hover { letter-spacing: 0.3em; }

	.hero-section {
		flex: 1; display: flex; justify-content: center; align-items: center;
		width: 100%; padding: 0 1.5rem; position: relative;
	}

	.spline-wrapper {
		position: absolute; bottom: -15dvh; left: 0; width: 100%; height: 115dvh;
		pointer-events: auto;
	}

	.spline-loading {
		position: absolute; inset: 0;
		background: linear-gradient(135deg, var(--skeleton-bg) 0%, transparent 50%, var(--skeleton-bg) 100%);
		background-size: 200% 200%;
		animation: shimmer 2s ease-in-out infinite;
		pointer-events: none;
		z-index: -1;
	}

	@keyframes shimmer {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}

	spline-viewer { width: 100%; height: 100%; }

	.hero-container {
		position: relative; top: 7vh; width: 100%; max-width: 1700px;
		display: flex; flex-direction: column; justify-content: center;
		align-items: center; gap: 2rem; pointer-events: none;
	}

	.hero-text {
		font-family: 'Montserrat', sans-serif;
		font-size: 9.2vw; font-weight: 900; text-transform: uppercase;
		letter-spacing: -0.05em; line-height: 0.8; text-align: center;
		width: 100%; margin: 0; padding: 0; white-space: nowrap;
		overflow: visible; pointer-events: none;
		text-wrap: balance;
		transition: letter-spacing 0.8s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.invert-text { color: #ffffff; mix-blend-mode: difference; }
	.highlight-red { color: var(--signature-color); }

	.hero-section:hover .hero-text { letter-spacing: -0.04em; }

	.hero-tagline {
		font-family: 'Montserrat', sans-serif;
		font-size: 1.1rem; font-weight: 500;
		letter-spacing: 0.15em; text-transform: uppercase;
		color: var(--text-secondary); text-align: center;
		opacity: 0; animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
		pointer-events: none;
	}

	.get-started-btn {
		background: none; border: none; outline: none; text-decoration: none;
		font-family: 'Montserrat', sans-serif;
		font-size: 1.2rem; font-weight: 900; text-transform: uppercase;
		letter-spacing: -0.02em; line-height: 1;
		color: #ffffff; opacity: 0; pointer-events: none;
		transition: opacity 1s ease, letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.get-started-btn.visible {
		opacity: 1;
		pointer-events: auto;
	}
	.get-started-btn.blend-active { mix-blend-mode: difference; opacity: unset; }
	.get-started-btn.visible:hover { letter-spacing: 0.05em; }

	.footer {
		display: flex; justify-content: space-between; align-items: center;
		width: 100%; padding: 2.5rem 3.5rem; z-index: 10;
		opacity: 0; animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
	}

	.footer-item {
		font-size: 0.65rem; font-weight: 500; text-transform: uppercase;
		letter-spacing: 0.15em; color: var(--text-color); font-variant: all-small-caps; white-space: nowrap;
	}

	.footer-link { text-decoration: none; color: var(--text-color); position: relative; padding-bottom: 2px; }
	.footer-link::after {
		content: ''; position: absolute; width: 100%; transform: scaleX(0);
		height: 1px; bottom: 0; left: 0; background-color: var(--text-color);
		transform-origin: bottom right; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.footer-link:hover::after { transform: scaleX(1); transform-origin: bottom left; }

	@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

	@media (max-width: 1200px) {
		.header { padding: 1.5rem 2rem; }
		.footer { padding: 1.5rem 2rem; }
		.hero-text { font-size: 10vw; }
		.get-started-btn { font-size: 1.1rem; }
		.hero-tagline { font-size: 1rem; }
	}

	@media (max-width: 900px) {
		.header { padding: 1.25rem 1.5rem; }
		.footer { padding: 1.5rem; display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; justify-items: start; }
		.footer-item:nth-child(even) { justify-self: end; text-align: right; }
		.hero-text { font-size: 11vw; }
		.get-started-btn { font-size: 1.05rem; }
		.hero-tagline { font-size: 0.9rem; letter-spacing: 0.1em; }
		.hero-container { gap: 1.5rem; }
	}

	@media (max-width: 600px) {
		.header { padding: 1rem 1.25rem; }
		.header-left { font-size: 0.65rem; letter-spacing: 0.15em; }
		.header-right { font-size: 0.65rem; letter-spacing: 0.1em; gap: 0.5rem; }
		.theme-toggle { font-size: 0.65rem; letter-spacing: 0.1em; }
		.footer { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; align-items: center; text-align: center; }
		.footer-item { font-size: 0.6rem; letter-spacing: 0.1em; }
		.footer-item:nth-child(even) { justify-self: center; text-align: center; }
		.hero-text { font-size: 12vw; white-space: normal; line-height: 0.9; }
		.get-started-btn { font-size: 0.9rem; }
		.hero-tagline { font-size: 0.75rem; letter-spacing: 0.08em; }
		.hero-container { gap: 1.25rem; top: 5vh; }
	}

	@media (max-width: 400px) {
		.header { padding: 0.75rem 1rem; }
		.header-left { font-size: 0.55rem; letter-spacing: 0.1em; }
		.header-right { font-size: 0.55rem; letter-spacing: 0.08em; }
		.theme-toggle { font-size: 0.55rem; letter-spacing: 0.08em; }
		.hero-text { font-size: 14vw; }
		.get-started-btn { font-size: 0.8rem; }
		.hero-tagline { font-size: 0.65rem; }
	}

	@media (pointer: coarse) {
		.get-started-btn.visible { padding: 0.5rem 0; }
		.theme-toggle { padding: 0.4rem 0; }
	}
</style>
