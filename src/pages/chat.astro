---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MindChat AI — Chat with AI" description="Chat with MindChat AI, your free and private AI assistant powered by Gemini. Ask questions, get answers.">
	<main class="page-container">

		<header class="header">
			<div class="header-left">
				<svg class="header-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" width="20" height="20" aria-hidden="true">
					<defs>
						<linearGradient id="header-logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="#ff3b30"/>
							<stop offset="100%" stop-color="#d42020"/>
						</linearGradient>
					</defs>
					<path d="M 48,24 H 80 C 93,24 104,35 104,48 V 72 C 104,85 93,96 80,96 H 58 L 40,110 V 96 H 48 C 35,96 24,85 24,72 V 48 C 24,35 35,24 48,24 Z" fill="url(#header-logo-grad)" opacity="0.08"/>
					<path d="M 48,24 H 80 C 93,24 104,35 104,48 V 72 C 104,85 93,96 80,96 H 58 L 40,110 V 96 H 48 C 35,96 24,85 24,72 V 48 C 24,35 35,24 48,24 Z" fill="none" stroke="url(#header-logo-grad)" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
					<path d="M 46,70 V 54 C 46,43 55,43 59,50 L 64,57 L 69,50 C 73,43 82,43 82,54 V 70" fill="none" stroke="currentColor" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round"/>
					<circle cx="64" cy="57" r="3.5" fill="currentColor" />
					<circle cx="53.5" cy="46" r="2.5" fill="currentColor" />
					<circle cx="74.5" cy="46" r="2.5" fill="currentColor" />
				</svg>
				<span>MindChat AI</span>
			</div>
			<div class="header-right">
				<button class="theme-toggle interactive" id="theme-toggle" aria-label="Toggle theme">Dark Mode</button>
				<span class="divider">·</span>
				<a href="/" class="header-link interactive">← Home</a>
			</div>
		</header>

		<div class="spline-wrapper">
			<spline-viewer url="https://prod.spline.design/sT38-ZSmhHN8uuqF/scene.splinecode" loading="eager" events-target="global"></spline-viewer>
			<div class="spline-loading"></div>
		</div>

		<section class="chat-section">
			<div class="chat-window">
				<div class="chat-messages" id="chat-messages">
					<div class="message system-message">
						<div class="message-content">
							Hello! I am <strong>MindChat AI</strong>. How can I help you today?
						</div>
					</div>
				</div>

				<div class="chat-options-panel" id="chat-options-panel">
					<form class="chat-form" id="chat-form">
						<input type="text" id="chat-input" placeholder="Ask MindChat AI..." autocomplete="off" />
						<button type="submit" class="send-btn interactive" id="send-btn">Send</button>
					</form>

					<div class="chat-controls">
						<button class="control-btn interactive" id="clear-btn">Clear Conversation</button>
					</div>

					<div class="suggested-prompts" id="suggested-prompts">
						<button class="prompt-chip" data-prompt="What can you do?">What can you do?</button>
						<button class="prompt-chip" data-prompt="Tell me a fun fact">Tell me a fun fact</button>
						<button class="prompt-chip" data-prompt="Write a short poem">Write a short poem</button>
						<button class="prompt-chip" data-prompt="Explain AI in simple terms">Explain AI simply</button>
					</div>
				</div>
			</div>
		</section>

		<footer class="footer">
			<div class="footer-item"><a href="/privacy" class="footer-link">Privacy Policy</a></div>
			<div class="footer-item"><a href="/about" class="footer-link">About Us</a></div>
			<div class="footer-item"><a href="/terms" class="footer-link">Terms & Conditions</a></div>
			<div class="footer-item"><a href="/contact" class="footer-link">Contact Us</a></div>
		</footer>

	</main>
</Layout>

<script>
	const API_URL = 'https://mindchat-proxy.nivedmohan5423.workers.dev';

	let chatTimeoutId: any = null;

	function getTimestamp() {
		return new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
	}

	async function initChat() {
		const chatForm = document.getElementById('chat-form') as HTMLFormElement;
		const chatInput = document.getElementById('chat-input') as HTMLInputElement;
		const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
		const chatMessages = document.getElementById('chat-messages');
		const clearBtn = document.getElementById('clear-btn');
		const chatOptionsPanel = document.getElementById('chat-options-panel');

		if (chatOptionsPanel) {
			if (chatTimeoutId) clearTimeout(chatTimeoutId);
			chatOptionsPanel.classList.remove('visible');
			chatTimeoutId = setTimeout(() => {
				chatOptionsPanel.classList.add('visible');
			}, 800);
		}

		let chatHistory: Array<{role: string, parts: Array<{text: string}>}> = [];
		let isWaiting = false;

		function parseMarkdown(text: string) {
			let escaped = text
				.replace(/&/g, "&amp;")
				.replace(/</g, "&lt;")
				.replace(/>/g, "&gt;");

			const codeBlocks: string[] = [];
			escaped = escaped.replace(/```(\w*)\n?([\s\S]*?)```/g, (_m: string, _l: string, code: string) => {
				const i = codeBlocks.length;
				codeBlocks.push(`<pre class="chat-code-block"><code>${code.replace(/^\n+|\n+$/g, '')}</code></pre>`);
				return `__CODE_BLOCK_PLACEHOLDER_${i}__`;
			});

			const inlineCodes: string[] = [];
			escaped = escaped.replace(/`(.*?)`/g, (_m: string, code: string) => {
				const i = inlineCodes.length;
				inlineCodes.push(`<code class="chat-code">${code}</code>`);
				return `__INLINE_CODE_PLACEHOLDER_${i}__`;
			});

			escaped = escaped.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
			escaped = escaped.replace(/\n/g, '<br>');

			inlineCodes.forEach((html, i) => escaped = escaped.replace(`__INLINE_CODE_PLACEHOLDER_${i}__`, html));
			codeBlocks.forEach((html, i) => escaped = escaped.replace(`__CODE_BLOCK_PLACEHOLDER_${i}__`, html));
			return escaped;
		}

		function scrollToBottom() {
			if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;
		}

		function appendMessage(role: 'user' | 'system-error', text: string) {
			if (!chatMessages) return;
			const div = document.createElement('div');
			div.className = `message ${role}-message`;
			const content = document.createElement('div');
			content.className = 'message-content';
			const textDiv = document.createElement('div');
			textDiv.innerHTML = parseMarkdown(text);
			content.appendChild(textDiv);
			const footer = document.createElement('div');
			footer.className = 'message-footer';
			const time = document.createElement('span');
			time.className = 'message-time';
			time.textContent = getTimestamp();
			footer.appendChild(time);
			if (role === 'user') {
				const copyBtn = document.createElement('button');
				copyBtn.className = 'copy-btn';
				copyBtn.textContent = 'Copy';
				copyBtn.addEventListener('click', (e) => {
					e.stopPropagation();
					navigator.clipboard.writeText(text);
					copyBtn.textContent = 'Copied!';
					setTimeout(() => copyBtn.textContent = 'Copy', 2000);
				});
				footer.appendChild(copyBtn);
			}
			content.appendChild(footer);
			div.appendChild(content);
			chatMessages.appendChild(div);
			scrollToBottom();
		}

		function appendAIMessage(text: string) {
			if (!chatMessages) return;
			const div = document.createElement('div');
			div.className = 'message model-message';
			const content = document.createElement('div');
			content.className = 'message-content';
			const textEl = document.createElement('div');
			content.appendChild(textEl);

			const footer = document.createElement('div');
			footer.className = 'message-footer';
			const time = document.createElement('span');
			time.className = 'message-time';
			time.textContent = getTimestamp();
			footer.appendChild(time);
			const copyBtn = document.createElement('button');
			copyBtn.className = 'copy-btn';
			copyBtn.textContent = 'Copy';
			copyBtn.addEventListener('click', (e) => {
				e.stopPropagation();
				navigator.clipboard.writeText(text);
				copyBtn.textContent = 'Copied!';
				setTimeout(() => copyBtn.textContent = 'Copy', 2000);
			});
			footer.appendChild(copyBtn);
			content.appendChild(footer);
			div.appendChild(content);
			chatMessages.appendChild(div);

			let pos = 0;
			const step = 5;
			const delay = 18;
			function tick() {
				pos += step;
				if (pos >= text.length) {
					textEl.innerHTML = parseMarkdown(text);
					scrollToBottom();
					return;
				}
				textEl.innerHTML = parseMarkdown(text.slice(0, pos));
				scrollToBottom();
				setTimeout(tick, delay);
			}
			setTimeout(tick, 300);
		}

		function hidePrompts() {
			const prompts = document.getElementById('suggested-prompts');
			if (prompts) prompts.style.display = 'none';
		}

		function showPrompts() {
			const prompts = document.getElementById('suggested-prompts');
			if (prompts) prompts.style.display = 'flex';
		}

		if (clearBtn && chatMessages) {
			clearBtn.addEventListener('click', () => {
				chatHistory = [];
				chatMessages.innerHTML = `<div class="message system-message"><div class="message-content">Conversation history cleared. I am <strong>MindChat AI</strong>. How can I help you today?</div></div>`;
				showPrompts();
			});
		}

		document.querySelectorAll('.prompt-chip').forEach(btn => {
			btn.addEventListener('click', () => {
				if (!chatInput || !chatForm || isWaiting) return;
				const text = btn.getAttribute('data-prompt') || '';
				chatInput.value = text;
				chatForm.dispatchEvent(new Event('submit', { cancelable: true }));
			});
		});

		if (chatForm) {
			chatForm.addEventListener('submit', async (e) => {
				e.preventDefault();
				if (!chatInput || isWaiting) return;
				const message = chatInput.value.trim();
				if (!message) return;

				isWaiting = true;
				sendBtn.disabled = true;
				hidePrompts();

				appendMessage('user', message);
				chatInput.value = '';

				const loadingDiv = document.createElement('div');
				loadingDiv.className = 'message model-message loading';
				loadingDiv.innerHTML = '<div class="message-content"><span class="dot">.</span><span class="dot">.</span><span class="dot">.</span></div>';
				chatMessages?.appendChild(loadingDiv);
				scrollToBottom();

				// Check for matching custom replies (special Hetvi trigger)
				const normalizedMessage = message.toLowerCase().replace(/[?.,!"]/g, "").trim();
				if (normalizedMessage === "hi i am hetvi") {
					setTimeout(() => {
						loadingDiv.remove();
						
						// Turn interface to baby pink color smoothly
						document.documentElement.setAttribute('data-theme', 'pink');

						const text = "hello to the cutest , prettiest , gorgeous person the world\nhow can i help you sweetheart";
						appendAIMessage(text);
						chatHistory.push({ role: 'user', parts: [{ text: message }] });
						chatHistory.push({ role: 'model', parts: [{ text }] });
						isWaiting = false;
						sendBtn.disabled = false;
					}, 800); // Simulate network thinking latency
					return;
				}

				try {
					const response = await fetch(API_URL, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							contents: [
								...chatHistory,
								{ role: 'user', parts: [{ text: message }] }
							],
							systemInstruction: {
								parts: [{ text: "You are MindChat AI — the world's most intelligent assistant. You are helpful, concise, and thoughtful." }]
							}
						})
					});

					loadingDiv.remove();

					if (!response.ok) {
						const err = await response.json().catch(() => ({}));
						const errMsg = err.error?.message || err.error || `Server error (${response.status})`;
						throw new Error(errMsg);
					}

					const data = await response.json();
					const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
					if (!text) throw new Error("Empty response from AI.");

					appendAIMessage(text);
					chatHistory.push({ role: 'user', parts: [{ text: message }] });
					chatHistory.push({ role: 'model', parts: [{ text }] });

				} catch (error: any) {
					loadingDiv.remove();
					appendMessage('system-error', error.message || 'An unexpected error occurred.');
				} finally {
					isWaiting = false;
					sendBtn.disabled = false;
				}
			});
		}

		document.addEventListener('keydown', (e) => {
			if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
				e.preventDefault();
				chatInput?.focus();
			}
		});
	}

	// Run immediately on initial load
	initChat();

	document.addEventListener('astro:page-load', initChat);
</script>

<style>
	.page-container {
		display: flex; flex-direction: column; justify-content: space-between;
		height: 100dvh; width: 100%; position: relative;
		background-color: var(--bg-color); overflow: hidden;
		transition: background-color 0.8s ease;
	}

	.spline-wrapper {
		position: absolute; bottom: -15dvh; left: 0; width: 100%; height: 115dvh;
		pointer-events: none;
		opacity: 0.15;
		z-index: 1;
	}

	.spline-loading {
		position: absolute; inset: 0;
		background: linear-gradient(135deg, var(--skeleton-bg) 0%, transparent 50%, var(--skeleton-bg) 100%);
		background-size: 200% 200%;
		animation: shimmer 2s ease-in-out infinite;
		pointer-events: none;
		z-index: -1;
	}

	@keyframes shimmer {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}

	spline-viewer { width: 100%; height: 100%; }

	.header {
		display: flex; justify-content: space-between; align-items: center;
		width: 100%; padding: 2.5rem 3.5rem; position: relative; z-index: 20;
	}

	.header-left {
		display: flex; align-items: center; gap: 0.6rem;
		font-size: 0.75rem; font-weight: 900; text-transform: uppercase;
		letter-spacing: 0.25em; color: var(--hero-color); font-variant: all-small-caps;
	}

	.header-logo {
		width: 20px; height: 20px; flex-shrink: 0;
	}

	.header-right {
		display: flex; align-items: center; gap: 0.75rem;
		font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
		letter-spacing: 0.2em; color: var(--hero-color);
	}

	.header-link { text-decoration: none; color: inherit; }
	.divider { color: var(--text-muted); }

	.theme-toggle {
		background: none; border: none; outline: none; cursor: pointer;
		font-family: 'Montserrat', sans-serif;
		font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
		letter-spacing: 0.2em; color: var(--hero-color); padding: 0;
		transition: letter-spacing 0.3s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s;
	}
	.theme-toggle:hover { letter-spacing: 0.3em; }

	.chat-section {
		flex: 1; display: flex; justify-content: center; align-items: center;
		width: 100%; padding: 0 3.5rem; overflow: hidden;
		position: relative; z-index: 5;
	}

	.chat-window {
		width: 100%; max-width: 800px; height: 100%;
		display: flex; flex-direction: column; justify-content: space-between;
		padding-bottom: 2rem; position: relative;
	}

	.chat-messages {
		flex: 1; overflow-y: auto; display: flex; flex-direction: column;
		gap: 1rem; padding: 1rem 0.5rem 1rem 0;
		scrollbar-width: thin; scrollbar-color: rgba(0,0,0,0.1) transparent;
	}

	.chat-messages::-webkit-scrollbar { width: 6px; }
	.chat-messages::-webkit-scrollbar-thumb { background-color: rgba(0,0,0,0.1); border-radius: 3px; }

	:global(.message) { display: flex; width: 100%; animation: fadeInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
	:global(.message-content) { max-width: 75%; padding: 0.9rem 1.2rem; font-size: 0.9rem; line-height: 1.5; word-break: break-word; transition: background-color 0.8s ease, color 0.8s ease; }

	:global(.user-message) { justify-content: flex-start; }
	:global(.user-message .message-content) { background-color: var(--card-bg); color: var(--text-primary); border-radius: 12px 12px 12px 2px; }

	:global(.model-message) { justify-content: flex-end; }
	:global(.model-message .message-content) { background-color: var(--model-bg); color: var(--model-text); border-radius: 12px 12px 2px 12px; }

	:global(.system-message) { justify-content: center; }
	:global(.system-message .message-content) { background: transparent; color: var(--text-muted); font-size: 0.8rem; text-align: center; max-width: 90%; padding: 0.5rem; }

	:global(.system-error-message) { justify-content: flex-start; }
	:global(.system-error-message .message-content) { background-color: var(--error-bg); color: var(--error-color); border: 1px solid rgba(212,32,32,0.15); border-radius: 8px; font-size: 0.85rem; font-weight: 500; }

	:global(.loading .dot) { display: inline-block; animation: blink 1.4s infinite both; font-size: 1.5rem; line-height: 0.5; margin: 0 0.1rem; }
	:global(.loading .dot:nth-child(2)) { animation-delay: .2s; }
	:global(.loading .dot:nth-child(3)) { animation-delay: .4s; }

	@keyframes blink { 0% { opacity: .2; } 20% { opacity: 1; } 100% { opacity: .2; } }

	:global(.message-footer) {
		display: flex; justify-content: flex-end; align-items: center;
		gap: 0.75rem; margin-top: 0.5rem; opacity: 0;
		transition: opacity 0.3s;
	}
	:global(.message:hover .message-footer) { opacity: 1; }
	:global(.user-message .message-footer) { justify-content: flex-start; }

	:global(.message-time) {
		font-size: 0.65rem; color: var(--text-muted);
		font-weight: 500; letter-spacing: 0.05em;
	}
	:global(.model-message .message-time) { color: rgba(255,255,255,0.5); }

	:global(.copy-btn) {
		background: none; border: none; outline: none; cursor: pointer;
		font-family: 'Montserrat', sans-serif;
		font-size: 0.6rem; font-weight: 700; text-transform: uppercase;
		letter-spacing: 0.1em; color: var(--text-muted); padding: 0;
		transition: color 0.3s;
	}
	:global(.model-message .copy-btn) { color: rgba(255,255,255,0.5); }
	:global(.copy-btn:hover) { color: var(--text-primary); }
	:global(.model-message .copy-btn:hover) { color: #ffffff; }

	.chat-options-panel {
		display: flex; flex-direction: column; width: 100%;
		opacity: 0; pointer-events: none;
		transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.chat-options-panel.visible {
		opacity: 1; pointer-events: auto;
	}

	.chat-form {
		display: flex; gap: 0.75rem; width: 100%; background-color: var(--card-bg);
		padding: 0.75rem 1.25rem; border-radius: 8px; align-items: center;
		border: 1px solid var(--border-color);
		transition: background-color 0.8s ease, border-color 0.8s ease;
	}

	.chat-form:focus-within { border-color: var(--signature-color); }
	.chat-form input { flex: 1; border: none; outline: none; background: none; font-family: 'Montserrat', sans-serif; font-size: 16px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-primary); padding: 0; }
	.chat-form input::placeholder { color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; }

	.chat-form .send-btn {
		background: none; border: none; outline: none;
		font-family: 'Montserrat', sans-serif; font-size: 0.75rem; font-weight: 800;
		text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-primary); cursor: pointer;
		padding: 0.25rem 0.5rem;
		transition: letter-spacing 0.3s cubic-bezier(0.16, 1, 0.3, 1), color 0.3s;
	}

	.chat-form .send-btn:disabled { color: var(--text-muted); cursor: not-allowed; }
	.chat-form .send-btn:not(:disabled):hover { letter-spacing: 0.25em; }

	.chat-controls { display: flex; justify-content: flex-end; width: 100%; margin-top: 0.75rem; }

	.control-btn {
		background: none; border: none; outline: none;
		font-family: 'Montserrat', sans-serif; font-size: 0.6rem; font-weight: 700;
		text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); cursor: pointer;
		transition: color 0.3s;
	}
	.control-btn:hover { color: var(--text-primary); }

	.suggested-prompts {
		display: flex; flex-wrap: wrap; gap: 0.5rem; width: 100%;
		margin-top: 0.75rem; justify-content: center;
	}

	.prompt-chip {
		background: none; border: 1px solid var(--border-color); outline: none; cursor: pointer;
		font-family: 'Montserrat', sans-serif; font-size: 0.7rem; font-weight: 600;
		color: var(--text-secondary); padding: 0.4rem 0.9rem;
		border-radius: 100px; transition: all 0.3s;
	}
	.prompt-chip:hover {
		border-color: var(--signature-color);
		color: var(--signature-color);
		background-color: rgba(212,32,32,0.05);
	}

	:global(.chat-code) { background-color: var(--code-bg); padding: 0.15rem 0.35rem; border-radius: 4px; font-family: 'Courier New', monospace; font-size: 0.85em; font-weight: 600; }
	:global(.model-message .chat-code) { background-color: rgba(255,255,255,0.12); color: var(--model-text); }
	:global(.chat-code-block) { background-color: var(--code-block-bg); color: var(--code-block-text); padding: 0.85rem 1rem; border-radius: 6px; overflow-x: auto; font-family: 'Courier New', monospace; font-size: 0.8em; margin: 0.75rem 0; white-space: pre; text-align: left; }
	:global(.user-message .chat-code-block) { background-color: var(--skeleton-bg); color: var(--text-primary); }

	@keyframes fadeInUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

	.footer {
		display: flex; justify-content: space-between; align-items: center;
		flex-wrap: wrap; gap: 1rem 2rem;
		width: 100%; padding: 2.5rem 3.5rem; position: relative; z-index: 10;
		opacity: 0; animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
	}

	.footer-item {
		font-size: 0.65rem; font-weight: 500; text-transform: uppercase;
		letter-spacing: 0.15em; color: var(--text-color); font-variant: all-small-caps; white-space: nowrap;
	}

	.footer-link { text-decoration: none; color: var(--text-color); position: relative; padding-bottom: 2px; }
	.footer-link::after {
		content: ''; position: absolute; width: 100%; transform: scaleX(0);
		height: 1px; bottom: 0; left: 0; background-color: var(--text-color);
		transform-origin: bottom right; transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.footer-link:hover::after { transform: scaleX(1); transform-origin: bottom left; }

	@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

	@media (max-width: 900px) {
		.header { padding: 1.5rem 2rem; }
